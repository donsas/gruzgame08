# Public site URL (optional on Vercel — auto from VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL)
NEXT_PUBLIC_URL=

# After Remix deploy on Base Mainnet
NEXT_PUBLIC_GRUZGAME08_CONTRACT_ADDRESS=0xE7cD8d5Ee95150cba37629B915aB3C7F63ec5aCe

# From base.dev → Settings → Builder Codes (gruzgame08)
NEXT_PUBLIC_GRUZGAME08_BUILDER_CODE=

# Optional: explicit ERC-8021 suffix hex (overrides auto-encode from builder code)
